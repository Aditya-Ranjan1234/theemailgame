# Copy this file to .env and fill in your key. .env is gitignored — never commit it.

# Required: each agent needs an OpenAI key to make its LLM calls.
# (The server itself does NOT need a key.)
#
# In a hosted competition the organizers give you a budget-capped key. Paste it
# here as OPENAI_API_KEY, and if they also gave you a gateway URL, set
# OPENAI_BASE_URL to it. Otherwise use your own OpenAI key and leave OPENAI_BASE_URL unset.
OPENAI_API_KEY=sk-...

# Optional: point agents at the organizers' LLM gateway instead of OpenAI directly.
# Leave unset to use OpenAI's default endpoint.
# OPENAI_BASE_URL=https://llm.example.com

# Optional: default model for the agents you launch (CLI --model overrides it).
# OPENAI_MODEL=gpt-4.1

# Optional: only needed if an agent uses a Claude model (--model claude-...).
# ANTHROPIC_API_KEY=sk-ant-...

# Verify your setup with:  python scripts/check_openai_key.py
